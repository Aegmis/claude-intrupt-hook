# Required
INTRUPT_BASE_URL=https://api.aegmis.com
INTRUPT_API_KEY=sk_org_xxxx_yyyy
INTRUPT_ORG_ID=org_xxxx

# Optional tuning
INTRUPT_GATED_TOOLS=Bash,Write,Edit
INTRUPT_TIMEOUT=600
INTRUPT_POLL_INTERVAL=5

# Bypass approval for specific Bash commands (comma-separated regex)
# Example: skip approval for git status and ls
# INTRUPT_BYPASS_PATTERNS=^git\s+status$,^ls\b
